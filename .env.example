# Copy to .env and fill in values — .env is gitignored
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/${POSTGRES_DB}
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=change_me

POSTGRES_DB=reconcile
POSTGRES_USER=reconcile
POSTGRES_PASSWORD=change_me

SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# For container profile — set to your OIDC issuer URI
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://your-idp.example.com

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
